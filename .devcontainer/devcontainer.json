// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/jekyll
{
  "name": "Jekyll Site With AWS Backend",

  // This image includes Jekyll 4.4.1 on Ruby 3.4.8. See https://github.com/devcontainers/images/tree/main/src/jekyll/history
  // Node and npm packages are included via a devcontainer feature.
  // This is Debian 12 (Bookworm), which approx matches Ubuntu 22.04 LTS (Jammy Jellyfish), see rough Debian/Ubuntu version mapping: https://askubuntu.com/questions/445487/what-debian-version-are-the-different-ubuntu-versions-based-on
  // Make sure these versions match the Jekyll version in Gemfile and Ruby version in GitHub Actions workflows
  "image": "mcr.microsoft.com/devcontainers/jekyll:2.2.7-3.4-bookworm",
  
  // Features to add to the dev container. More info: https://containers.dev/features.
  "features": {
    "ghcr.io/devcontainers/features/git:1": {
      "version": "os-provided"
    },
    "ghcr.io/devcontainers/features/git-lfs:1": {
      "autoPull": true,
      "installDirectlyFromGitHubRelease": true,
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/aws-cli:1": {
      "version": "2.34.12"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    }
    // CDK is installed via npm, see package.json
    // Also there's no devcontainer feature for Jekyll, it's just in our devcontainer base image
  },
  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  "forwardPorts": [
    4000, // Jekyll server
    9229  // Node.js debugging
  ],

  // Ensure the ~/.gnupg dir exists, otherwise the bind mount below will fail.
  // mkdir -p option ensures no error if the dir already exists.
  "initializeCommand": "mkdir -p ${localEnv:HOME}${localEnv:USERPROFILE}/.gnupg/",

  // Object syntax for these commands allows commands to run in parallel (https://containers.dev/implementors/spec/#parallel-exec)
  // Dotfiles are cloned/run _after_ these commands
  "onCreateCommand": {
    "aptUpdate": "sudo apt-get update && sudo apt-get upgrade --yes",
    
    // Update npm, but not in GitHub Actions runners; that always seems to fail due to weird permissions errors
    // See https://github.com/devcontainers/ci/issues/437
    "updateNpm": "test -z $GITHUB_ACTIONS && npm install --global npm@11.12.0 || echo \"Not updating npm in GitHub Actions runner\""
  },
  "updateContentCommand": {
    "npm": "cd cdk/ && npm install",
    "bundle": "cd web/ && bundle install"
  },

  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      // Add the IDs of extensions you want installed when the container is created.
      // Make sure appropriate common extensions from this list are added to .vscode/extensions.json and all other devcontainer.json files as well.
      "extensions": [
        "mikestead.dotenv",
        "eamodio.gitlens",
        "ms-azuretools.vscode-docker",
        "GitHub.vscode-github-actions",
        "GitHub.vscode-pull-request-github",
        "DavidAnson.vscode-markdownlint",
        "streetsidesoftware.code-spell-checker"
      ]
    }
  },
  "mounts": [
    // Uncomment to use the Docker CLI from inside the container. See https://aka.ms/vscode-remote/samples/docker-from-docker.
    // "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gnupg/,target=/home/vscode/.gnupg/,type=bind"
  ]
  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  // "remoteUser": "root"
}